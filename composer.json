{
    "name": "mosaicora/module-opengraph",
    "version": "1.0.3",
    "description": "Open Graph and Twitter Card metadata module for Magento 2, Mage-OS, and Adobe Commerce, with image optimization, REST, and GraphQL APIs",
    "keywords": [
        "adobe commerce",
        "graphql",
        "mage-os",
        "magento",
        "magento2",
        "open graph",
        "social metadata",
        "twitter cards"
    ],
    "homepage": "https://github.com/Mosaicora/module-opengraph",
    "type": "magento2-module",
    "license": [
        "GPL-3.0-or-later"
    ],
    "authors": [
        {
            "name": "Dragan Atanasov",
            "email": "hello@mosaicora.io",
            "homepage": "https://mosaicora.io"
        }
    ],
    "support": {
        "issues": "https://github.com/Mosaicora/module-opengraph/issues",
        "source": "https://github.com/Mosaicora/module-opengraph"
    },
    "require": {
        "php": "~8.1.0||~8.2.0||~8.3.0||~8.4.0||~8.5.0",
        "magento/framework": "^103.0",
        "magento/module-backend": "^102.0",
        "magento/module-catalog": "^104.0",
        "magento/module-catalog-graph-ql": "^100.4",
        "magento/module-cms": "^104.0",
        "magento/module-cms-graph-ql": "^100.4",
        "magento/module-config": "^101.2",
        "magento/module-eav": "^102.1",
        "magento/module-graph-ql": "^100.4",
        "magento/module-store": "^101.1",
        "magento/module-store-graph-ql": "^100.4",
        "magento/module-ui": "^101.2",
        "magento/module-webapi": "^100.4"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://repo.magento.com/"
        }
    ],
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.1",
        "magento/magento-coding-standard": "^40.0",
        "phpunit/phpunit": "^10.5 || ^11.5 || ^12.0",
        "squizlabs/php_codesniffer": "^3.10.2"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "magento/composer-dependency-version-audit-plugin": true
        }
    },
    "scripts": {
        "phpcs": "phpcs --standard=phpcs.xml",
        "test": "phpunit --configuration phpunit.xml.dist"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Mosaicora\\OpenGraph\\": ""
        }
    }
}
